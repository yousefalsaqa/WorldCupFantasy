// ============================================
// WORLD CUP 2026 FANTASY - DATABASE SCHEMA
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  // Read-only activity — updated (best-effort, fire-and-forget) whenever the
  // user's client hits the squad or league-standings GET routes, so "has he
  // even looked at his team" is answerable without a mutating action.
  // lastLoginAt alone undercounts activity: JWT sessions persist for days,
  // so a user can transfer/view without ever hitting /login again.
  lastSquadViewAt  DateTime?
  lastLeagueViewAt DateTime?
  isAdmin       Boolean   @default(false)
  
  team          Team?
  sessions      Session[]
  leaguesOwned  League[]  @relation("LeagueOwner")
  leagueMemberships LeagueMembership[]
  
  @@index([email])
  @@index([username])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ipAddress String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([token])
  @@index([userId])
}

// ============================================
// NATIONS (instead of clubs)
// ============================================

model Nation {
  id            String   @id @default(cuid())
  name          String   @unique  // e.g., "Brazil"
  code          String   @unique  // e.g., "BRA"
  flagUrl       String?
  group         String?  // e.g., "C"
  isEliminated  Boolean  @default(false)
  eliminatedAt  String?  // Stage where eliminated (e.g., "R32")
  
  // Kit colors for player cards
  kitColor1     String   @default("#FFFFFF")  // Primary kit color
  kitColor2     String   @default("#000000")  // Secondary/number color
  
  // API-Football integration
  apiFootballId Int?     @unique  // External team ID from API-Football
  
  players       Player[]
  homeMatches   Match[]  @relation("HomeNation")
  awayMatches   Match[]  @relation("AwayNation")
  
  @@index([code])
  @@index([group])
  @@index([isEliminated])
  @@index([apiFootballId])
}

model Player {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  displayName   String
  position      String   // GK, DEF, MID, FWD
  nationId      String
  currentPrice  Float    @default(5.0)
  photoUrl      String?
  shirtNumber   Int?
  isAvailable   Boolean  @default(true)
  availabilityNote String?
  
  // API-Football integration
  apiFootballId Int?     @unique  // External player ID from API-Football
  
  nation        Nation   @relation(fields: [nationId], references: [id])
  
  squadPlayers  SquadPlayer[]
  performances  PlayerPerformance[]
  
  @@index([nationId])
  @@index([position])
  @@index([currentPrice])
  @@index([apiFootballId])
}

// Position values: GK, DEF, MID, FWD

// ============================================
// TOURNAMENT STAGES & MATCHES
// ============================================

model Stage {
  id            String   @id @default(cuid())
  stageId       String   @unique  // e.g., "GR1", "R32", "QF"
  name          String   // e.g., "Group Stage - Round 1"
  order         Int      // For sorting
  deadlineTime  DateTime?
  isActive      Boolean  @default(false)
  isComplete    Boolean  @default(false)
  
  matches       Match[]
  teamStages    TeamStage[]
  
  @@index([stageId])
  @@index([order])
}

model Match {
  id            String   @id @default(cuid())
  stageId       String
  homeNationId  String
  awayNationId  String
  kickoffTime   DateTime
  
  // Results
  homeScore     Int?
  awayScore     Int?
  isStarted     Boolean  @default(false)
  isFinished    Boolean  @default(false)
  
  // For knockouts
  homePenalties Int?     // Penalty shootout
  awayPenalties Int?
  winnerId      String?  // Nation that won (for knockouts)
  // The 3rd-place play-off and the Final now share Stage "F" (see the
  // 3RD/F merge) — this flags which of the two a Match row is, since both
  // have the same stageId. false/default = the Final.
  isThirdPlace  Boolean  @default(false)
  
  // API-Football integration
  apiFootballId Int?     @unique  // External fixture ID from API-Football
  
  // Live match tracking
  currentMinute Int?     // Current minute (for live updates)
  lastUpdated   DateTime? // Last time live data was fetched

  // Match-detail cache for the fixture modal (stats/lineups/events).
  // JSON string: { fetchedAt, final, payload }. Fetched on demand from
  // API-Football; short TTL while live, frozen forever once final.
  detailCache   String?

  // Admin-entered predicted lineups (from editorial sources, e.g. FotMob
  // screenshots). JSON string — see src/lib/predicted-lineups.ts. Shown
  // in the fixture modal's Lineups tab ONLY until the official lineups
  // arrive from API-Football, then ignored.
  predictedLineups String?

  stage         Stage    @relation(fields: [stageId], references: [id])
  homeNation    Nation   @relation("HomeNation", fields: [homeNationId], references: [id])
  awayNation    Nation   @relation("AwayNation", fields: [awayNationId], references: [id])
  
  performances  PlayerPerformance[]
  
  @@index([stageId])
  @@index([kickoffTime])
  @@index([apiFootballId])
  @@index([isStarted])
}

// ============================================
// PLAYER PERFORMANCE
// ============================================

model PlayerPerformance {
  id                    String   @id @default(cuid())
  playerId              String
  matchId               String
  
  minutesPlayed         Int      @default(0)
  goals                 Int      @default(0)
  assists               Int      @default(0)
  cleanSheet            Boolean  @default(false)
  goalsConceeded        Int      @default(0)
  saves                 Int      @default(0)
  penaltiesSaved        Int      @default(0)
  penaltiesMissed       Int      @default(0)
  yellowCards           Int      @default(0)
  redCards              Int      @default(0)
  ownGoals              Int      @default(0)
  bonusPoints           Int      @default(0)

  // Defensive Contributions — raw count of (tackles + interceptions +
  // blocks + duels.won). Used to recompute the per-match points
  // breakdown when admins/users open the player modal.
  defensiveActions      Int      @default(0)

  // Was the player in the starting XI (vs came off the bench)? From
  // API-Football's games.substitute flag. Null on rows written before
  // this column existed (backfillable). Drives the "Started last match"
  // selection chip in the squad builder.
  startedMatch          Boolean?

  totalPoints           Int      @default(0)
  
  // Live tracking
  isLive                Boolean  @default(false)  // Currently in a live match
  lastUpdated           DateTime? // Last time stats were fetched from API
  
  player  Player @relation(fields: [playerId], references: [id])
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  @@unique([playerId, matchId])
  @@index([playerId])
  @@index([matchId])
  @@index([isLive])
}

// ============================================
// FANTASY TEAMS & SQUADS
// ============================================

model Team {
  id              String   @id @default(cuid())
  userId          String   @unique
  name            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  // When the first COMPLETE (15-player) squad was saved. The late-joiner
  // gate compares this (falling back to createdAt for pre-existing rows)
  // against the stage deadline: miss the deadline → no points that stage.
  firstSquadSavedAt DateTime?
  
  // Budget
  initialBudget   Float    @default(100.0)
  bankBalance     Float    @default(100.0)
  teamValue       Float    @default(0.0)
  
  // Transfers tracking (resets per stage)
  freeTransfers   Int      @default(2)
  transfersUsed   Int      @default(0)
  // JSON array of transfers queued while the active round is locked.
  // Applied automatically by stage-advance when the next round starts.
  // Shape: [{ playerOutId, playerInId, priceIn, priceOut, queuedAt }]
  pendingTransfers String?

  // JSON lineup the user arranged for the PLANNED (next-round) squad — the
  // current 15 with queued transfers applied. Lets them set the next-round
  // formation/bench/captain independently of the locked current lineup.
  // Applied right after pendingTransfers at the stage boundary, then cleared.
  // Shape: { startingXI: string[], bench: string[], captainId, viceCaptainId }
  // Ids are FINAL player ids (incoming where transferred, current otherwise).
  plannedLineup    String?

  // Chips
  wildcard1Used   Boolean  @default(false)
  wildcard2Used   Boolean  @default(false)
  tripleCaptainUsed Boolean @default(false)
  benchBoostUsed  Boolean  @default(false)
  freeHitUsed     Boolean  @default(false)
  // JSON snapshot of squad+team state at the moment Free Hit was activated.
  // Restored automatically once the activation stage ends.
  freeHitSnapshot String?
  
  // Points
  totalPoints     Int      @default(0)
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  squadPlayers    SquadPlayer[]
  teamStages      TeamStage[]
  transfers       Transfer[]
  leagueMemberships LeagueMembership[]
  
  @@index([totalPoints])
}

model SquadPlayer {
  id              String   @id @default(cuid())
  teamId          String
  playerId        String
  purchasePrice   Float
  points          Int      @default(0)  // Points scored this stage
  
  isStarting      Boolean  @default(false)
  isCaptain       Boolean  @default(false)
  isViceCaptain   Boolean  @default(false)
  benchOrder      Int?     // 1-5 if on bench
  
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])
  
  @@unique([teamId, playerId])
  @@index([teamId])
  @@index([playerId])
}

// ============================================
// STAGE SNAPSHOTS (Points per stage)
// ============================================

model TeamStage {
  id              String   @id @default(cuid())
  teamId          String
  stageId         String
  
  rawPoints       Int      @default(0)
  captainPoints   Int      @default(0)
  transferHits    Int      @default(0)
  totalPoints     Int      @default(0)
  
  // Single-chip pointer (legacy). Kept in sync with the FIRST entry of
  // chipsUsed so older read paths keep working. New code reads chipsUsed.
  chipUsed        String?  // WILDCARD_1, WILDCARD_2, TRIPLE_CAPTAIN, BENCH_BOOST, FREE_HIT
  // JSON-encoded array of activated chip IDs for this team+stage. Allows
  // stacking (e.g. TRIPLE_CAPTAIN + BENCH_BOOST in the same gameweek).
  // Example: '["TRIPLE_CAPTAIN","BENCH_BOOST"]'. Null when no chip is active.
  chipsUsed       String?
  
  // Snapshot of squad at deadline
  squadSnapshot   String?  // JSON
  
  // Eliminated players count (for mercy rule)
  eliminatedCount Int      @default(0)
  mercyTransfers  Int      @default(0)
  
  team     Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  stage    Stage @relation(fields: [stageId], references: [id])
  
  @@unique([teamId, stageId])
  @@index([teamId])
  @@index([stageId])
}

// ChipType values: WILDCARD_1, WILDCARD_2, TRIPLE_CAPTAIN, BENCH_BOOST

// ============================================
// TRANSFERS
// ============================================

model Transfer {
  id            String   @id @default(cuid())
  teamId        String
  stageId       String?
  playerInId    String
  playerOutId   String
  priceIn       Float
  priceOut      Float
  isFreeTransfer Boolean @default(true)
  isMercyTransfer Boolean @default(false) // From mercy rule
  isWildcard    Boolean  @default(false)
  createdAt     DateTime @default(now())
  
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  @@index([teamId])
  @@index([stageId])
}

// ============================================
// LEAGUES
// ============================================

model League {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  ownerId     String
  isGlobal    Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  owner       User     @relation("LeagueOwner", fields: [ownerId], references: [id])
  memberships LeagueMembership[]
  
  @@index([code])
}

model LeagueMembership {
  id        String   @id @default(cuid())
  leagueId  String
  teamId    String
  userId    String
  joinedAt  DateTime @default(now())
  
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([leagueId, teamId])
  @@index([leagueId])
  @@index([teamId])
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())
  // When this entry was reverted (via /api/admin/override DELETE for
  // manual point adjustments). Null = still in effect. UIs hide
  // reverted entries from default views so they don't clutter the
  // Adjustments list with +X/-X pairs.
  revertedAt        DateTime?
  // ID of the audit entry that reverted this one (a row whose action
  // is "MANUAL_OVERRIDE_REVERTED"). Lets admins trace cause/effect.
  revertedByAuditId String?
  
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ============================================
// APP SETTINGS
// ============================================
// Tiny key/value store for app-wide flags that need to be toggled at
// runtime (vs env vars which require a redeploy). The only consumer right
// now is the player-table lock, which the seed script reads to refuse to
// wipe a production DB once admin has locked the table.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}
